{
  "name": "veridit",
  "private": true,
  "scripts": {
    "dev": "turbo run build --filter=@veridit/contracts && turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "prisma:generate": "turbo run prisma:generate",
    "prisma:migrate": "turbo run prisma:migrate",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
